---
import Reveal from "../animations/Reveal.astro";

const areas = [
    { name: "Psicanálise de Adultos", detail: "Atendimento Profundo" },
    { name: "Psicodinâmica Infantil", detail: "Neurodivergentes & TEA" },
    { name: "Transtornos de Humor", detail: "Depressão & Ansiedade" },
    { name: "Terapia de Casal & Familiar", detail: "Suporte Sistêmico" },
    { name: "Sexologia Clínica", detail: "Acompanhamento Especializado" },
];

const differentials = [
    { name: "Neurociência Aplicada", detail: "Rigor Técnico" },
    { name: "Atendimento Online", detail: "Alcance Global" },
    { name: "Atendimento Presencial", detail: "Araguari - MG" },
    { name: "Abordagem Humanizada", detail: "Ética & Acolhimento" },
];
---

<section id="pricing" class="py-24 bg-transparent border-t border-white/5">
    <div class="container mx-auto px-6">
        <div class="max-w-3xl mx-auto">
            <Reveal direction="up">
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-serif mb-4 text-brand">
                        Áreas de Atuação
                    </h2>
                    <p
                        class="text-charcoal/60 uppercase tracking-widest text-xs"
                    >
                        Especialidades e Enfoques Terapêuticos
                    </p>
                </div>
            </Reveal>

            <Reveal direction="up" delay={200}>
                <div
                    class="bg-[#111111] border border-white/5 p-8 md:p-12 rounded-sm shadow-2xl relative overflow-hidden group"
                >
                    <!-- Subtle Glow Effect -->
                    <div
                        class="absolute -top-24 -right-24 w-48 h-48 bg-brand/10 blur-[100px] rounded-full group-hover:bg-brand/20 transition-all duration-700"
                    >
                    </div>

                    <div class="relative z-10">
                        <div class="mb-12">
                            <h3
                                class="text-2xl font-serif text-white mb-8 border-b border-white/10 pb-4 inline-block"
                            >
                                Especialidades
                            </h3>
                            <div class="space-y-6">
                                {
                                    areas.map((item) => (
                                        <div class="flex justify-between items-end border-b border-white/5 pb-2 hover:border-brand/30 transition-colors duration-300">
                                            <span class="text-white/80 font-light text-base md:text-lg">
                                                {item.name}
                                            </span>
                                            <span class="text-brand font-medium tracking-tight">
                                                {item.detail}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>

                        <div>
                            <h3
                                class="text-2xl font-serif text-white mb-8 border-b border-white/10 pb-4 inline-block"
                            >
                                Diferenciais
                            </h3>
                            <div class="space-y-6">
                                {
                                    differentials.map((item) => (
                                        <div class="flex justify-between items-end border-b border-white/5 pb-2 hover:border-brand/30 transition-colors duration-300">
                                            <span class="text-white/80 font-light pr-4 text-base md:text-lg">
                                                {item.name}
                                            </span>
                                            <span class="text-brand font-medium tracking-tight whitespace-nowrap">
                                                {item.detail}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>

                        <div
                            class="mt-12 pt-8 border-t border-white/10 text-center space-y-6"
                        >
                            <div
                                class="inline-block px-8 py-4 border-2 border-brand/40 bg-brand/10 rounded-sm shadow-[0_0_30px_rgba(99,102,241,0.15)]"
                            >
                                <p
                                    class="text-brand text-sm md:text-base uppercase tracking-[0.3em] font-bold"
                                >
                                    Agende sua primeira sessão
                                </p>
                                <p
                                    class="text-white/60 text-[10px] uppercase tracking-widest mt-2 font-light"
                                >
                                    Acolhimento profissional e especializado
                                </p>
                            </div>

                            <p
                                class="text-white/40 text-xs italic leading-relaxed max-w-sm mx-auto pt-4"
                            >
                                * Os valores das sessões são informados durante o primeiro contato, respeitando a ética profissional e as particularidades de cada caso.
                            </p>

                            <div class="pt-4">
                                <a
                                    href={`https://wa.me/5534984036388?text=${encodeURIComponent("Olá Elizabeth! Vim através do seu site. Gostaria de informações sobre valores e disponibilidade de horários.")}`}
                                    target="_blank"
                                    class="btn-premium inline-block px-12 py-4"
                                >
                                    Entrar em contato
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </Reveal>
        </div>
    </div>
</section>
