---
import Reveal from "../animations/Reveal.astro";

import { MonitorSmartphone, MapPin, ShieldCheck, HeartPulse } from "lucide-react";
---

<section id="pricing" class="py-24 bg-transparent border-t border-white/5 relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand/5 rounded-full blur-[120px] -z-10"></div>
    
    <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center mb-20">
            <Reveal direction="up">
                <span class="text-brand text-sm uppercase tracking-[0.3em] font-medium mb-4 block">Acesso ao Cuidado</span>
                <h2 class="text-4xl md:text-6xl font-serif mb-6 text-white leading-tight">
                    Modalidades de <span class="italic text-brand">Atendimento</span>
                </h2>
                <p class="text-charcoal/70 text-lg font-normal leading-relaxed max-w-2xl mx-auto">
                    A terapia deve se adaptar à sua realidade, não o contrário. Ofereço ambientes seguros e preparados para que o seu processo ocorra com o mesmo rigor, seja de onde você estiver.
                </p>
            </Reveal>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto mb-16">
            <!-- Modalidade Presencial -->
            <Reveal direction="up" delay={100}>
                <div class="relative group h-full bg-white/[0.02] border border-white/10 p-10 md:p-14 hover:border-brand/40 transition-all duration-700 rounded-2xl overflow-hidden flex flex-col justify-between">
                    <div class="absolute top-0 right-0 p-8 text-brand/10 group-hover:text-brand/20 transition-colors duration-500">
                        <MapPin size={120} strokeWidth={1} />
                    </div>
                    
                    <div class="relative z-10">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="p-3 bg-brand/10 text-brand rounded-xl">
                                <MapPin size={24} />
                            </div>
                            <h3 class="text-3xl font-serif text-white">Presencial</h3>
                        </div>
                        
                        <p class="text-white/60 text-lg leading-relaxed font-light mb-8">
                            Um espaço físico sofisticado e acolhedor em Araguari - MG. Pensado nos mínimos detalhes para proporcionar o máximo de conforto, sigilo e tranquilidade durante o seu momento.
                        </p>
                        
                        <ul class="space-y-4 text-white/50 mb-10 border-t border-white/5 pt-8">
                            <li class="flex items-center gap-3">
                                <ShieldCheck size={18} className="text-brand/60" />
                                <span class="text-sm">Ambiente seguro e totalmente sigiloso</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <HeartPulse size={18} className="text-brand/60" />
                                <span class="text-sm">Foco integral e sem interrupções</span>
                            </li>
                        </ul>
                    </div>

                    <a
                        href={`https://wa.me/5534984036388?text=${encodeURIComponent("Olá Elizabeth! Tenho interesse em agendar um Atendimento Presencial.")}`}
                        target="_blank"
                        class="relative z-10 block w-full py-4 text-center border-2 border-white/10 text-white uppercase tracking-widest text-xs font-semibold hover:bg-white hover:text-[#050505] transition-all duration-300 rounded-lg"
                    >
                        Agendar Presencial
                    </a>
                </div>
            </Reveal>

            <!-- Modalidade Online -->
            <Reveal direction="up" delay={200}>
                <div class="relative group h-full bg-brand/[0.03] border border-brand/20 p-10 md:p-14 hover:border-brand/50 transition-all duration-700 rounded-2xl overflow-hidden flex flex-col justify-between shadow-[0_0_40px_rgba(192,138,126,0.05)]">
                    <div class="absolute top-0 right-0 p-8 text-brand/10 group-hover:text-brand/20 transition-colors duration-500">
                        <MonitorSmartphone size={120} strokeWidth={1} />
                    </div>
                    
                    <div class="relative z-10">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="p-3 bg-brand text-white rounded-xl shadow-lg shadow-brand/20">
                                <MonitorSmartphone size={24} />
                            </div>
                            <h3 class="text-3xl font-serif text-white">Online</h3>
                        </div>
                        
                        <p class="text-white/60 text-lg leading-relaxed font-light mb-8">
                            Acompanhamento clínico de alto nível sem barreiras geográficas. Reúna-se comigo através de plataformas seguras, no conforto e privacidade do seu próprio lar, independente de qual país você esteja.
                        </p>
                        
                        <ul class="space-y-4 text-white/50 mb-10 border-t border-brand/10 pt-8">
                            <li class="flex items-center gap-3">
                                <ShieldCheck size={18} className="text-brand/80" />
                                <span class="text-sm">Chamadas criptografadas e pontuais</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <HeartPulse size={18} className="text-brand/80" />
                                <span class="text-sm">Mesmo rigor técnico do presencial</span>
                            </li>
                        </ul>
                    </div>

                    <a
                        href={`https://wa.me/5534984036388?text=${encodeURIComponent("Olá Elizabeth! Tenho interesse em agendar um Atendimento Online.")}`}
                        target="_blank"
                        class="relative z-10 block w-full py-4 text-center bg-brand text-white uppercase tracking-widest text-xs font-semibold hover:bg-brand-light transition-all duration-300 rounded-lg shadow-lg hover:shadow-brand/20 cursor-pointer"
                    >
                        Agendar Online
                    </a>
                </div>
            </Reveal>
        </div>

        <!-- Etica Adicional -->
        <Reveal direction="up" delay={300}>
            <div class="max-w-2xl mx-auto text-center mt-12 bg-white/[0.01] border border-white/5 rounded-2xl p-6 md:p-8 backdrop-blur-sm">
                <p class="text-white/40 text-[11px] md:text-sm uppercase tracking-widest leading-relaxed">
                    * Os valores dos honorários, regras de remarcação e detalhes terapêuticos são informados durante nosso primeiro contato, em conformidade com o código de ética profissional e priorizando sua individualidade.
                </p>
            </div>
        </Reveal>
    </div>
</section>
