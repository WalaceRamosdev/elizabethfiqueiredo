---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import Pricing from "../components/sections/Pricing.astro";
import Services from "../components/sections/Services.astro";
import Methodology from "../components/sections/Methodology.astro";
import About from "../components/sections/About.astro";
import CustomCursor from "../components/ui/CustomCursor.astro";
import Header from "../components/ui/Header.astro";
import Reveal from "../components/animations/Reveal.astro";
---

<Layout title="Elizabeth Figueiredo | Psicanalista Clínica">
	<CustomCursor />

	<Header />

	<main>
		<Hero />
		<Pricing />
		<Services />
		<Methodology />
		<About />

		<!-- CTA Seção -->
		<section class="py-24 bg-brand text-white text-center">
			<div class="container mx-auto px-6">
				<Reveal direction="up">
					<h2
						class="text-4xl md:text-5xl font-serif mb-8 leading-tight"
					>
						Comece sua jornada de autoconhecimento
					</h2>
					<p class="text-white/85 mb-12 max-w-xl mx-auto font-normal">
						O equilíbrio emocional e a compreensão da mente são os primeiros passos para uma vida plena. 
						Agende sua consulta presencial ou online.
					</p>
					<a
						href="https://wa.me/5534984036388?text=Ol%C3%A1!%20Vim%20atrav%C3%A9s%20do%20seu%20site."
						target="_blank"
						class="inline-block px-12 py-4 border border-white text-white hover:bg-white hover:text-brand transition-all duration-500 rounded-sm"
					>
						Agendar Consulta
					</a>
				</Reveal>
			</div>
		</section>
	</main>

	<footer class="py-12 bg-transparent border-t border-white/5">
		<div class="container mx-auto px-6 text-center">
			<p
				class="text-white/40 text-[10px] uppercase tracking-widest leading-relaxed"
			>
				&copy; 2026 Elizabeth Figueiredo. Psicanálise Clínica e Especialista.
				<br />
				Desenvolvido por
				<a
					href="https://www.sitesalphacode.com.br/solucoes/psicologos"
					target="_blank"
					class="text-brand hover:text-brand-light transition-colors font-medium border-b border-brand/20"
				>
					Alpha Code
				</a>
			</p>
		</div>
	</footer>
</Layout>
